# Copy to .env and fill in values.
# Database (required for projects, users, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname
PGSSL=false

# Server
PORT=3001

# Optional: force screen-flip prank for a specific user id (Cooper Smith)
# COOPER_PRANK_USER_ID=12

# Optional override for URLs inside emails (drawings button, portals, variation approve).
# If unset, links default to https://portal.superiorgrannyflats.com.au — not the sender's localhost/LAN browser.
PUBLIC_APP_URL=

# SMTP (required for sending emails from Project Info → Send Test)
# Office 365 / Outlook:
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@superiorgrannyflats.com.au
SMTP_PASS=your-app-password

# Gmail: use App Password (not account password).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
