# Copy to .env and fill in values.
# Database (required for projects, users, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname
PGSSL=false

# Server
PORT=3001

# Public base URL of the web app (no trailing slash). Use for production email links (phones / off‑LAN).
# Examples: https://app.yourdomain.com   or   http://your-public-ip:3001
# The app also sends linkBaseUrl from the browser when you send mail; dev uses that + Vite server.host.
PUBLIC_APP_URL=

# SMTP (required for sending emails from Project Info → Send Test)
# Office 365 / Outlook:
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@superiorgrannyflats.com.au
SMTP_PASS=your-app-password

# Gmail: use App Password (not account password).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
